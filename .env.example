# Roomie production environment template.
# Copy this file to .env for local development. Never commit real .env files.
# Vite injects only VITE_ prefixed values into the browser bundle.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com

# Server-only API keys. Configure these in Vercel/Firebase hosting environment
# variables, not in client code.
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# WebRTC TURN configuration. Production video calls require an owned TURN service.
VITE_TURN_URL=turn:your-turn.example.com:3478
VITE_TURN_USERNAME=your_turn_username
VITE_TURN_PASSWORD=your_turn_password

# Optional advanced ICE override as JSON. Leave empty unless you need a full
# custom RTCIceServer array.
VITE_ICE_SERVERS=
