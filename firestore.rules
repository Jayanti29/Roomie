rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Community Users (Presence)
    match /community_users/{userEmailSlug} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.token.email.replace('\\.', '_') == userEmailSlug || request.auth.uid == userEmailSlug);
    }

    // Friends lists
    match /friends_lists/{userEmailSlug} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.token.email.replace('\\.', '_') == userEmailSlug || request.auth.uid == userEmailSlug);
    }

    // Study Rooms
    match /study_rooms/{roomId} {
      allow read, write: if isAuthenticated();
      
      // WebRTC signaling subcollection
      match /calls/{callId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Global Notes Board
    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (resource == null || resource.data.authorUid == request.auth.uid || request.resource.data.authorUid == request.auth.uid);
    }

    // Channels
    match /channels/{channelId} {
      allow read, write: if isAuthenticated();
    }

    // Study Groups
    match /study_groups/{groupId} {
      allow read, write: if isAuthenticated();
    }
  }
}
